# ─────────────────────────────────────────────────────────────────────────────
# RAG SaaS - Environment Configuration Template
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Application
ENVIRONMENT=development        # development | staging | production
DEBUG=false

# SECURITY — Generate strong random values for production:
# python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING
JWT_SECRET_KEY=CHANGE_THIS_TO_ANOTHER_RANDOM_64_CHAR_STRING
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL
POSTGRES_DB=rag_saas
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_DB_PASSWORD
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_THIS_STRONG_DB_PASSWORD@postgres:5432/rag_saas

# Redis
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_THIS_REDIS_PASSWORD@redis:6379/0

# ── LLM / Embedding Provider Selection ──────────────────────────────────────
# LLM_PROVIDER: gemini (default)
# EMBEDDING_PROVIDER: gemini (default) | ollama (requires local Ollama)
LLM_PROVIDER=gemini
EMBEDDING_PROVIDER=gemini

# Gemini Flash — Google AI LLM + Embeddings
# Get your API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=models/gemma-3-12b-it
GEMINI_MAX_TOKENS=2048
GEMINI_TEMPERATURE=0.0
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# Ollama — Optional local embeddings (only needed if EMBEDDING_PROVIDER=ollama)
# Install Ollama: https://ollama.com/download
# Pull embedding model: ollama pull nomic-embed-text
# When using Docker, point to host machine:
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ChromaDB
CHROMA_PERSIST_DIR=/app/data/chroma

# File Storage
UPLOAD_BASE_DIR=/app/data/uploads
MAX_FILE_SIZE_MB=50

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_CHAT_REQUESTS=20
RATE_LIMIT_CHAT_WINDOW_SECONDS=60

# CORS — Update with your actual frontend domain(s)
# JSON array format: ["https://app.yourdomain.com","https://yourdomain.com"]
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_FILE=/app/logs/app.log

# RAG Configuration
CHUNK_SIZE=2000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5
MAX_QUERY_LENGTH=2000

# API Rate Limits (Google AI Free Tier)
EMBEDDING_RPM=100
LLM_RPM=30
EMBEDDING_BATCH_SIZE=10

# Security
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Workers (1 for dev, 4 for production)
WORKERS=1
